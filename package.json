{
	"name": "svelte-sv-extension",
	"version": "1.0.0",
	"description": "Use .sv files as Svelte components in SvelteKit.",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sandersonstabo/svelte-sv-extension.git"
	},
	"bin": {
		"svelte-sv-extension": "./.dist/cli.mjs"
	},
	"files": [
		".dist",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./.dist/config.d.ts",
			"default": "./.dist/mod.mjs"
		},
		"./config": {
			"types": "./.dist/config.d.ts",
			"default": "./.dist/config.mjs"
		},
		"./init": {
			"types": "./.dist/init.d.ts",
			"default": "./.dist/init.mjs"
		},
		"./cli": {
			"types": "./.dist/cli.d.ts",
			"default": "./.dist/cli.mjs"
		}
	},
	"scripts": {
		"build": "vp pack && tsc -p tsconfig.build.json",
		"check": "vp check",
		"fmt": "vp fmt . --write",
		"lint": "vp lint",
		"test": "vp pack && tsc -p tsconfig.build.json && vp test run"
	},
	"dependencies": {
		"jsonc-parser": "^3.3.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@types/node": "^26.1.0",
		"svelte": "^5.0.0",
		"typescript": "^6.0.0",
		"vite": "catalog:",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0 || ^3.0.0-next.0",
		"svelte": "^5.0.0",
		"vite": "^8.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0",
			"onFail": "download"
		}
	},
	"engines": {
		"node": "^22.12.0 || >=24.0.0"
	},
	"packageManager": "pnpm@11.10.0"
}
