{
  "name": "svelte-sv-extension",
  "version": "0.1.0",
  "description": "Use .sv files as Svelte components in SvelteKit.",
  "license": "BSD-3-Clause",
  "type": "module",
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandersonstabo/svelte-sv-extension.git"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/mod.ts",
      "default": "./src/mod.js"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.js"
    }
  },
  "scripts": {
    "check": "deno task check",
    "fmt": "deno task fmt",
    "lint": "deno task lint",
    "test": "deno task test"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0 || ^3.0.0-next.0",
    "svelte": "^5.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "vite": "^8.0.0"
  }
}
