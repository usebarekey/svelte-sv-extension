{
  "name": "@sandersonstabo/svelte-sv-extension",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./config": "./src/config.ts",
    "./init": "./src/init.ts",
    "./cli": "./src/cli.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "es2022"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.0.0",
    "jsonc-parser": "npm:jsonc-parser@^3.3.1",
    "typescript": "npm:typescript@^6.0.0"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno run -A scripts/build-js-mirrors.ts",
    "check": "deno check src/mod.ts src/config.ts src/init.ts src/cli.ts src/mod.js src/config.js src/init.js src/cli.js",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test -A .tests/"
  }
}
